{
  "expo": {
    "name": "Pie Matrix",
    "slug": "piematrix",
    "scheme": "com.thepiematrix.app",
    "version": "1.2.4",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030308"
    },
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "com.thepiematrix.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pie Matrix needs your location to show the sky above you.",
        "NSMotionUsageDescription": "Pie Matrix uses motion sensors for AR sky navigation."
      },
      "appleTeamId": "H2458LP837"
    },
    "android": {
      "package": "com.thepiematrix.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030308"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.HIGH_SAMPLING_RATE_SENSORS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-sensors",
      "expo-location",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#d4c5a0"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Poppins-Light.ttf",
            "./assets/fonts/Poppins-Regular.ttf",
            "./assets/fonts/Poppins-Medium.ttf",
            "./assets/fonts/Poppins-SemiBold.ttf",
            "./assets/fonts/Poppins-Bold.ttf",
            "./assets/fonts/Poppins-ExtraBold.ttf",
            "./assets/fonts/Poppins-Black.ttf"
          ]
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-asset",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Pie Matrix uses this to provide a personalized experience and show relevant sky events. You can change this anytime in Settings."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "042f458e-668c-449b-b461-635fbd4a6518"
      }
    },
    "owner": "piematrix"
  }
}
